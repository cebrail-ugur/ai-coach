# =============================================================================
# ChatApp Ultra - Ortam Değişkenleri
# =============================================================================
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin:
#   cp .env.example .env
#
# .env dosyası git'e eklenmez (.gitignore'da engellidir).
# Üretim ortamında bu değişkenleri hosting platformunuzda (Vercel, Railway vb.)
# ortam değişkeni olarak tanımlayın.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — ZORUNLU
# Supabase Console → Settings → API bölümünden alın
# https://supabase.com/dashboard/project/<proje-id>/settings/api
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=https://faajqjrrkjwmrkconegx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_GSDLh-PAaAP-d8sif7fN0w_bLSy_gx5


# -----------------------------------------------------------------------------
# FIREBASE FCM — OPSİYONEL (Push bildirimleri için)
# Firebase olmadan uygulama çalışır, sadece push bildirimler devre dışı kalır.
# Firebase Console → Project Settings → General → Your apps → Web app
# https://console.firebase.google.com
# -----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID Key: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# ÖNEMLİ: Firebase Service Worker'ı da güncelleyin:
# client/public/firebase-messaging-sw.js içindeki firebaseConfig nesnesini
# yukarıdaki değerlerle manuel doldurun (Service Worker import.meta.env okuyamaz).


# -----------------------------------------------------------------------------
# HARİTA — OPSİYONEL (Konum paylaşımı için)
# Forge API üzerinden Google Maps proxy'si kullanılır.
# https://forge.butterfly-effect.dev adresinden API key alın.
# -----------------------------------------------------------------------------

VITE_FRONTEND_FORGE_API_KEY=
# Varsayılan: https://forge.butterfly-effect.dev (boş bırakırsanız bu kullanılır)
VITE_FRONTEND_FORGE_API_URL=


# -----------------------------------------------------------------------------
# MANUS PLATFORM — Sadece Manus.app ortamında gerekli
# Manus dışı deployment'larda bu değişkenlere gerek yoktur.
# -----------------------------------------------------------------------------

VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=


# -----------------------------------------------------------------------------
# SUNUCU — OPSİYONEL
# Sadece `pnpm start` ile Express sunucu çalıştırılırken geçerlidir.
# Vite geliştirme sunucusu (pnpm dev) bu değişkenleri kullanmaz.
# -----------------------------------------------------------------------------

PORT=3000
NODE_ENV=development


# -----------------------------------------------------------------------------
# TURN SUNUCU — OPSİYONEL (Simetrik NAT arkasındaki kullanıcılar için)
# Boş bırakılırsa STUN ile P2P denenir; başarısız olursa arama kurulamaz.
# Önerilen sağlayıcılar: Twilio, Metered, Coturn (self-hosted)
# Format: turn:hostname:port  veya  turns:hostname:443
# -----------------------------------------------------------------------------

VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=


# -----------------------------------------------------------------------------
# ANTHROPIC CLAUDE API — ZORUNLU (/api/ai/chat endpoint için)
# API key VITE_ prefix'i olmadan tanımlanır — client bundle'a girmez.
# https://console.anthropic.com/settings/keys adresinden alın.
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
